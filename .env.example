# Copy this file to .env and fill in values you want to use.

# Search provider options: manual, brave, bing, serpapi
SEARCH_PROVIDER=manual

BRAVE_SEARCH_API_KEY=
BING_SEARCH_API_KEY=
SERPAPI_API_KEY=
SERPAPI_KEY=

LEADGEN_USER_AGENT=CargroLeadGenResearchBot/0.1 (+manual lead research; no automated outreach)
LEADGEN_TIMEOUT=12
LEADGEN_RATE_LIMIT_SECONDS=1.5
LEADGEN_MAX_PAGES_PER_DOMAIN=8
LEADGEN_MAX_CRAWL_DEPTH=2
LEADGEN_RESPECT_ROBOTS=true
LEADGEN_ENABLE_PLAYWRIGHT=false
